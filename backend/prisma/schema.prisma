generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Session {
  id        String    @id
  name      String
  subject   String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  messages  Message[]
}

model Message {
  id        String   @id
  role      String
  content   String
  timestamp DateTime @default(now())

  sessionId String
  session   Session @relation(fields: [sessionId], references: [id])
}
